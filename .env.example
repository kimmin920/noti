# publ-messaging MVP - .env.example
# Values must be provided via local .env (dev) or secret manager (prod). DO NOT COMMIT real secrets.

# -----------------------------
# App / Environment
# -----------------------------
NODE_ENV=development
APP_NAME=publ-messaging
APP_BASE_URL=http://localhost:3000

# Admin UI (Next.js)
ADMIN_BASE_URL=http://localhost:3010
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
# Local password login is only for local/dev or emergency break-glass access.
# Disable this in production and prefer Google OAuth / SSO.
LOCAL_PASSWORD_LOGIN_ENABLED=true
NEXT_PUBLIC_LOCAL_PASSWORD_LOGIN_ENABLED=true

# -----------------------------
# Auth (Publ SSO -> Session Cookie)
# -----------------------------
# Publ issues HS256 JWT; Messaging verifies with this shared secret.
PUBL_SSO_HS256_SECRET=__REPLACE_ME__

# Session cookie / server session secret (for signing/encrypting session data)
SESSION_SECRET=__REPLACE_ME__

# Google OAuth (optional admin login)
GOOGLE_OAUTH_CLIENT_ID=__REPLACE_ME__
GOOGLE_OAUTH_CLIENT_SECRET=__REPLACE_ME__
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/v1/auth/google/callback
GOOGLE_OAUTH_ALLOWED_DOMAIN=
GOOGLE_OAUTH_DEFAULT_TENANT_ID=tenant_demo
GOOGLE_OAUTH_DEFAULT_TENANT_NAME="Google Tenant"
GOOGLE_OAUTH_OPERATOR_EMAILS=
PUBL_ACCOUNTS=
SUPER_ADMIN_EMAILS=
PARTNER_ADMIN_EMAILS=
GOOGLE_OAUTH_OPERATOR_TENANT_ID=tenant_internal_ops
GOOGLE_OAUTH_OPERATOR_TENANT_NAME="Publ Internal Operations"
SUPER_ADMIN_TENANT_ID=tenant_internal_ops
SUPER_ADMIN_TENANT_NAME="Publ Internal Operations"
PARTNER_ADMIN_TENANT_ID=tenant_partner_publ
PARTNER_ADMIN_TENANT_NAME="Publ Partner Workspace"
GOOGLE_OAUTH_STATE_COOKIE_NAME=pm_oauth_state
GOOGLE_OAUTH_STATE_MAX_AGE_SECONDS=600

# Cookie settings
COOKIE_NAME=pm_session
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax
COOKIE_MAX_AGE_SECONDS=86400

# CORS / Allowed origins (comma-separated)
CORS_ALLOW_ORIGINS=http://localhost:3001,http://localhost:3000,http://localhost:3010

# Publ internal API authentication
PUBL_SERVICE_TOKEN=__REPLACE_ME__

# -----------------------------
# Database (PostgreSQL)
# -----------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/publ_messaging?schema=public

# -----------------------------
# Redis (BullMQ)
# -----------------------------
REDIS_URL=redis://localhost:6379
BULLMQ_QUEUE_NAME=publ_messaging_queue

# Worker rate limiting (Notification Hub: <=300 RPS)
NHN_RATE_LIMIT_RPS=300

# Poller schedule (seconds)
RESULT_POLLER_INTERVAL_SECONDS=120
# Additional early result checks after provider send (seconds, comma-separated)
RESULT_EARLY_CHECK_DELAYS_SECONDS=10,30

# -----------------------------
# Observability
# -----------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# -----------------------------
# NHN Cloud - Common (Notification Hub)
# -----------------------------
NHN_OAUTH_BASE_URL=https://oauth.api.nhncloudservice.com
NHN_NOTIFICATION_HUB_BASE_URL=https://notification-hub.api.nhncloudservice.com

# Used to create OAuth token (Basic Auth: base64(ID:SECRET))
NHN_USER_ACCESS_KEY_ID=__REPLACE_ME__
NHN_SECRET_ACCESS_KEY=__REPLACE_ME__

# X-NC-APP-KEY header for Notification Hub API
NHN_NOTIFICATION_HUB_APP_KEY=__REPLACE_ME__

# -----------------------------
# NHN Cloud - SMS API v3.0 (sender number sync)
# -----------------------------
NHN_SMS_BASE_URL=https://api-sms.cloud.toast.com
NHN_SMS_APP_KEY=__REPLACE_ME__
NHN_SMS_SECRET_KEY=__REPLACE_ME__

# -----------------------------
# NHN Cloud - KakaoTalk Bizmessage (Sender profile + Webhook)
# -----------------------------
NHN_ALIMTALK_BASE_URL=https://api-alimtalk.cloud.toast.com
NHN_ALIMTALK_APP_KEY=__REPLACE_ME__
NHN_ALIMTALK_SECRET_KEY=__REPLACE_ME__
# Sender profile group "senderKey", not the visible group ID like PUBL
NHN_DEFAULT_SENDER_GROUP_KEY=954b4486e661a019badabd5ebe15d7ef7e27cb31

# Webhook signature verification (KakaoTalk Bizmessage webhook)
NHN_WEBHOOK_SIGNATURE_SECRET=__REPLACE_ME__

# Public webhook URL (for documentation / display; actual server route is configured in app)
WEBHOOK_PUBLIC_URL=https://your-domain.example.com/v1/webhooks/nhn/kakao

# -----------------------------
# Feature flags (MVP)
# -----------------------------
FEATURE_ENABLE_ALIMTALK=true
FEATURE_ENABLE_ALIMTALK_FALLBACK_SMS=true
FEATURE_ENABLE_SMS=true
MESSAGE_PURPOSE=NORMAL

# -----------------------------
# Google OAuth (optional)
# -----------------------------
GOOGLE_OAUTH_CLIENT_ID=__REPLACE_ME__
GOOGLE_OAUTH_CLIENT_SECRET=__REPLACE_ME__
GOOGLE_OAUTH_REDIRECT_URI=https://api-speed-demon.vizuo.work/v1/auth/google/callback
GOOGLE_OAUTH_ALLOWED_DOMAIN=
GOOGLE_OAUTH_DEFAULT_TENANT_ID=tenant_demo
GOOGLE_OAUTH_DEFAULT_TENANT_NAME="Google Tenant"
GOOGLE_OAUTH_STATE_COOKIE_NAME=pm_oauth_state
GOOGLE_OAUTH_STATE_COOKIE_SECURE=true
GOOGLE_OAUTH_STATE_COOKIE_SAMESITE=lax
GOOGLE_OAUTH_STATE_COOKIE_DOMAIN=
GOOGLE_OAUTH_STATE_MAX_AGE_SECONDS=600
GOOGLE_OAUTH_OPERATOR_EMAILS=contact@vizuo.work
PUBL_ACCOUNTS=
SUPER_ADMIN_EMAILS=
PARTNER_ADMIN_EMAILS=
GOOGLE_OAUTH_OPERATOR_TENANT_ID=tenant_internal_ops
GOOGLE_OAUTH_OPERATOR_TENANT_NAME="Publ Internal Operations"
SUPER_ADMIN_TENANT_ID=tenant_internal_ops
SUPER_ADMIN_TENANT_NAME="Publ Internal Operations"
PARTNER_ADMIN_TENANT_ID=tenant_partner_publ
PARTNER_ADMIN_TENANT_NAME="Publ Partner Workspace"
