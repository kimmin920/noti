generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  PARTNER_ADMIN
  SUPER_ADMIN
}

enum AccessOrigin {
  DIRECT
  PUBL
}

enum LoginProvider {
  GOOGLE_OAUTH
  PUBL_SSO
  LOCAL_PASSWORD
}

enum MessageChannel {
  SMS
  ALIMTALK
  BRAND_MESSAGE
}

enum ChannelStrategy {
  SMS_ONLY
  ALIMTALK_ONLY
  ALIMTALK_THEN_SMS
}

enum MessagePurpose {
  NORMAL
}

enum AlimtalkTemplateBindingMode {
  DEFAULT
  CUSTOM
}

enum MessageRequestStatus {
  ACCEPTED
  PROCESSING
  SENT_TO_PROVIDER
  DELIVERED
  DELIVERY_FAILED
  SEND_FAILED
  CANCELED
  DEAD
}

enum TemplateStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ProviderTemplateStatus {
  REG
  REQ
  APR
  REJ
}

enum SenderNumberType {
  COMPANY
  EMPLOYEE
}

enum SenderNumberStatus {
  DRAFT
  SUBMITTED
  SUPPLEMENT_REQUESTED
  APPROVED
  REJECTED
}

enum SenderProfileStatus {
  ACTIVE
  BLOCKED
  DORMANT
  UNKNOWN
}

enum ManagedUserStatus {
  ACTIVE
  INACTIVE
  DORMANT
  BLOCKED
}

enum ManagedUserFieldType {
  TEXT
  NUMBER
  BOOLEAN
  DATE
  DATETIME
  JSON
}

enum BulkSmsCampaignStatus {
  PROCESSING
  SENT_TO_PROVIDER
  PARTIAL_FAILED
  FAILED
}

enum BulkSmsRecipientStatus {
  REQUESTED
  ACCEPTED
  FAILED
}

model DashboardNotice {
  id             String    @id @default(cuid())
  title          String
  body           String
  isPinned       Boolean   @default(false)
  createdBy      String?
  createdByEmail String?
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([archivedAt, isPinned, createdAt(sort: Desc)])
}

model AdminUser {
  id                     String           @id @default(cuid())
  providerUserId         String           @unique
  loginProvider          LoginProvider    @default(PUBL_SSO)
  loginId                String?          @unique
  email                  String?
  passwordHash           String?
  role                   UserRole         @default(USER)
  accessOrigin           AccessOrigin     @default(DIRECT)
  autoRechargeEnabled    Boolean          @default(false)
  lowBalanceAlertEnabled Boolean          @default(false)
  dailySendLimit         Int              @default(1000)
  monthlySmsLimit        Int              @default(1000)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  sessions               Session[]
  smsUsageLedgers        SmsUsageLedger[]
}

model ManagedUserField {
  id          String               @id @default(cuid())
  ownerUserId String
  key         String
  label       String
  dataType    ManagedUserFieldType @default(TEXT)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@unique([ownerUserId, key])
  @@index([ownerUserId, createdAt(sort: Desc)])
}

model ManagedUser {
  id                     String                      @id @default(cuid())
  ownerUserId            String
  source                 String
  externalId             String?
  name                   String
  email                  String?
  phone                  String?
  status                 ManagedUserStatus           @default(ACTIVE)
  userType               String?
  segment                String?
  gradeOrLevel           String?
  marketingConsent       Boolean?
  tags                   Json?
  registeredAt           DateTime?
  lastLoginAt            DateTime?
  customAttributes       Json?
  rawPayload             Json
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  bulkSmsRecipients      BulkSmsRecipient[]
  bulkAlimtalkRecipients BulkAlimtalkRecipient[]
  bulkBrandRecipients    BulkBrandMessageRecipient[]

  @@unique([ownerUserId, source, externalId])
  @@index([ownerUserId, updatedAt(sort: Desc)])
  @@index([ownerUserId, source, email])
  @@index([ownerUserId, source, phone])
}

model Session {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime  @default(now())
}

model EventRule {
  id                          String                      @id @default(cuid())
  ownerUserId                 String
  eventKey                    String
  displayName                 String
  enabled                     Boolean                     @default(true)
  channelStrategy             ChannelStrategy
  messagePurpose              MessagePurpose              @default(NORMAL)
  requiredVariables           Json
  smsTemplateId               String?
  smsTemplate                 Template?                   @relation("SmsTemplate", fields: [smsTemplateId], references: [id])
  smsSenderNumberId           String?
  smsSenderNumber             SenderNumber?               @relation(fields: [smsSenderNumberId], references: [id])
  alimtalkTemplateId          String?
  alimtalkTemplateBindingMode AlimtalkTemplateBindingMode @default(CUSTOM)
  alimtalkTemplate            ProviderTemplate?           @relation(fields: [alimtalkTemplateId], references: [id])
  alimtalkSenderProfileId     String?
  alimtalkSenderProfile       SenderProfile?              @relation(fields: [alimtalkSenderProfileId], references: [id])
  updatedAt                   DateTime                    @updatedAt
  updatedBy                   String?

  @@unique([ownerUserId, eventKey])
  @@index([ownerUserId, updatedAt(sort: Desc)])
}

model PublEventDefinition {
  id                        String                    @id @default(cuid())
  catalogKey                String?                   @unique
  eventKey                  String                    @unique
  displayName               String
  category                  String
  pAppCode                  String?
  pAppName                  String?
  triggerText               String?
  detailText                String?
  defaultTemplateSource     String?
  defaultTemplateOwnerKey   String?
  defaultTemplateOwnerLabel String?
  defaultTemplateName       String?
  defaultTemplateCode       String?
  defaultKakaoTemplateCode  String?
  defaultTemplateStatus     String?
  defaultTemplateBody       String?
  serviceStatus             String                    @default("ACTIVE")
  locationType              String?
  locationId                String?
  sourceType                String?
  actionType                String?
  docsVersion               String?
  editable                  Boolean                   @default(true)
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  props                     PublEventPropDefinition[]

  @@index([serviceStatus, category])
  @@index([updatedAt(sort: Desc)])
}

model PublEventPropDefinition {
  id             String              @id @default(cuid())
  eventId        String
  event          PublEventDefinition @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rawPath        String
  alias          String
  label          String
  type           String
  required       Boolean             @default(false)
  sample         String?
  description    String?
  fallback       String?
  parserPipeline Json?
  enabled        Boolean             @default(true)
  sortOrder      Int                 @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([eventId, rawPath])
  @@index([eventId, sortOrder])
}

model Template {
  id                String             @id @default(cuid())
  ownerUserId       String
  channel           MessageChannel
  name              String
  body              String
  syntax            String
  requiredVariables Json
  metadataJson      Json?
  status            TemplateStatus     @default(DRAFT)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  versions          TemplateVersion[]
  smsEventRules     EventRule[]        @relation("SmsTemplate")
  providerTemplates ProviderTemplate[]
  messageRequests   MessageRequest[]
  bulkSmsCampaigns  BulkSmsCampaign[]

  @@index([ownerUserId, channel, updatedAt(sort: Desc)])
}

model TemplateVersion {
  id                        String   @id @default(cuid())
  templateId                String
  template                  Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  version                   Int
  bodySnapshot              String
  requiredVariablesSnapshot Json
  createdBy                 String?
  createdAt                 DateTime @default(now())

  @@unique([templateId, version])
}

model ProviderTemplate {
  id                    String                 @id @default(cuid())
  ownerUserId           String
  channel               MessageChannel
  templateId            String
  template              Template               @relation(fields: [templateId], references: [id], onDelete: Cascade)
  nhnTemplateId         String?
  templateCode          String?
  kakaoTemplateCode     String?
  providerStatus        ProviderTemplateStatus @default(REG)
  rejectedReason        String?
  block                 Boolean?
  dormant               Boolean?
  lastSyncedAt          DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  eventRules            EventRule[]
  messageRequests       MessageRequest[]
  bulkAlimtalkCampaigns BulkAlimtalkCampaign[]

  @@index([ownerUserId, providerStatus])
}

model SenderNumber {
  id                                 String             @id @default(cuid())
  ownerUserId                        String
  phoneNumber                        String
  type                               SenderNumberType
  status                             SenderNumberStatus @default(DRAFT)
  telecomCertificatePath             String?
  consentDocumentPath                String?
  personalInfoConsentPath            String?
  idCardCopyPath                     String?
  thirdPartyBusinessRegistrationPath String?
  relationshipProofPath              String?
  additionalDocumentPath             String?
  employmentCertificatePath          String?
  reviewMemo                         String?
  reviewedBy                         String?
  approvedAt                         DateTime?
  syncedAt                           DateTime?
  createdAt                          DateTime           @default(now())
  updatedAt                          DateTime           @updatedAt
  eventRules                         EventRule[]
  messageRequests                    MessageRequest[]
  bulkSmsCampaigns                   BulkSmsCampaign[]
  smsUsageLedgers                    SmsUsageLedger[]

  @@unique([ownerUserId, phoneNumber])
  @@index([ownerUserId, status])
}

model SenderProfile {
  id                    String                     @id @default(cuid())
  ownerUserId           String
  plusFriendId          String
  senderKey             String
  senderProfileType     String                     @default("NORMAL")
  status                SenderProfileStatus        @default(UNKNOWN)
  isDefault             Boolean                    @default(false)
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  eventRules            EventRule[]
  messageRequests       MessageRequest[]
  bulkAlimtalkCampaigns BulkAlimtalkCampaign[]
  bulkBrandCampaigns    BulkBrandMessageCampaign[]

  @@unique([ownerUserId, senderKey])
  @@index([ownerUserId, status])
  @@index([ownerUserId, isDefault])
}

model MessageRequest {
  id                         String               @id @default(cuid())
  ownerUserId                String
  eventKey                   String
  idempotencyKey             String
  recipientPhone             String
  recipientUserId            String?
  variablesJson              Json
  metadataJson               Json?
  manualBody                 String?
  scheduledAt                DateTime?
  status                     MessageRequestStatus @default(ACCEPTED)
  resolvedChannel            MessageChannel?
  resolvedSenderNumberId     String?
  resolvedSenderNumber       SenderNumber?        @relation(fields: [resolvedSenderNumberId], references: [id])
  resolvedSenderProfileId    String?
  resolvedSenderProfile      SenderProfile?       @relation(fields: [resolvedSenderProfileId], references: [id])
  resolvedTemplateId         String?
  resolvedTemplate           Template?            @relation(fields: [resolvedTemplateId], references: [id])
  resolvedProviderTemplateId String?
  resolvedProviderTemplate   ProviderTemplate?    @relation(fields: [resolvedProviderTemplateId], references: [id])
  nhnMessageId               String?              @unique
  lastErrorCode              String?
  lastErrorMessage           String?
  attemptCount               Int                  @default(0)
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt
  attempts                   MessageAttempt[]
  deadLetters                DeadLetter[]
  smsUsageLedger             SmsUsageLedger?
  retryOfRequestId           String?
  retryOfRequest             MessageRequest?       @relation("MessageRequestRetries", fields: [retryOfRequestId], references: [id], onDelete: SetNull)
  retryRequests              MessageRequest[]      @relation("MessageRequestRetries")

  @@unique([ownerUserId, idempotencyKey])
  @@index([ownerUserId, createdAt(sort: Desc)])
  @@index([ownerUserId, eventKey, createdAt(sort: Desc)])
  @@index([ownerUserId, retryOfRequestId, createdAt(sort: Desc)])
}

model BulkSmsCampaign {
  id                  String                @id @default(cuid())
  ownerUserId         String
  title               String
  scheduledAt         DateTime?
  status              BulkSmsCampaignStatus @default(PROCESSING)
  senderNumberId      String
  senderNumber        SenderNumber          @relation(fields: [senderNumberId], references: [id])
  templateId          String?
  template            Template?             @relation(fields: [templateId], references: [id])
  body                String
  nhnRequestId        String?
  totalRecipientCount Int                   @default(0)
  skippedNoPhoneCount Int                   @default(0)
  duplicatePhoneCount Int                   @default(0)
  requestedBy         String?
  providerRequest     Json?
  providerResponse    Json?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  recipients          BulkSmsRecipient[]
  smsUsageLedger      SmsUsageLedger?

  @@index([ownerUserId, createdAt(sort: Desc)])
}

model BulkSmsRecipient {
  id                   String                 @id @default(cuid())
  campaignId           String
  campaign             BulkSmsCampaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  managedUserId        String?
  managedUser          ManagedUser?           @relation(fields: [managedUserId], references: [id], onDelete: SetNull)
  recipientPhone       String
  recipientName        String?
  recipientSeq         String?
  recipientGroupingKey String?
  templateParameters   Json?
  status               BulkSmsRecipientStatus @default(REQUESTED)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  @@index([campaignId, createdAt(sort: Asc)])
  @@index([managedUserId])
}

model SmsUsageLedger {
  id                String           @id @default(cuid())
  ownerUserId       String
  ownerUser         AdminUser        @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  senderNumberId    String?
  senderNumber      SenderNumber?    @relation(fields: [senderNumberId], references: [id], onDelete: SetNull)
  messageRequestId  String?          @unique
  messageRequest    MessageRequest?  @relation(fields: [messageRequestId], references: [id], onDelete: SetNull)
  bulkSmsCampaignId String?          @unique
  bulkSmsCampaign   BulkSmsCampaign? @relation(fields: [bulkSmsCampaignId], references: [id], onDelete: SetNull)
  quantity          Int
  usageAt           DateTime
  createdAt         DateTime         @default(now())

  @@index([ownerUserId, usageAt(sort: Desc)])
  @@index([senderNumberId, usageAt(sort: Desc)])
}

model BulkAlimtalkCampaign {
  id                  String                  @id @default(cuid())
  ownerUserId         String
  title               String
  scheduledAt         DateTime?
  status              BulkSmsCampaignStatus   @default(PROCESSING)
  senderProfileId     String
  senderProfile       SenderProfile           @relation(fields: [senderProfileId], references: [id])
  providerTemplateId  String?
  providerTemplate    ProviderTemplate?       @relation(fields: [providerTemplateId], references: [id])
  templateSource      String                  @default("LOCAL")
  templateName        String                  @default("")
  templateCode        String?
  body                String
  nhnRequestId        String?
  totalRecipientCount Int                     @default(0)
  skippedNoPhoneCount Int                     @default(0)
  duplicatePhoneCount Int                     @default(0)
  requestedBy         String?
  providerRequest     Json?
  providerResponse    Json?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  recipients          BulkAlimtalkRecipient[]

  @@index([ownerUserId, createdAt(sort: Desc)])
}

model BulkAlimtalkRecipient {
  id                   String                 @id @default(cuid())
  campaignId           String
  campaign             BulkAlimtalkCampaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  managedUserId        String?
  managedUser          ManagedUser?           @relation(fields: [managedUserId], references: [id], onDelete: SetNull)
  recipientPhone       String
  recipientName        String?
  recipientSeq         String?
  recipientGroupingKey String?
  templateParameters   Json?
  status               BulkSmsRecipientStatus @default(REQUESTED)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  @@index([campaignId, createdAt(sort: Asc)])
  @@index([managedUserId])
}

model BulkBrandMessageCampaign {
  id                  String                      @id @default(cuid())
  ownerUserId         String
  title               String
  scheduledAt         DateTime?
  status              BulkSmsCampaignStatus       @default(PROCESSING)
  senderProfileId     String
  senderProfile       SenderProfile               @relation(fields: [senderProfileId], references: [id])
  mode                String                      @default("FREESTYLE")
  messageType         String
  templateName        String?
  templateCode        String?
  body                String
  pushAlarm           Boolean                     @default(true)
  adult               Boolean                     @default(false)
  statsEventKey       String?
  resellerCode        String?
  imageUrl            String?
  imageLink           String?
  buttonsJson         Json?
  nhnRequestId        String?
  totalRecipientCount Int                         @default(0)
  skippedNoPhoneCount Int                         @default(0)
  duplicatePhoneCount Int                         @default(0)
  requestedBy         String?
  providerRequest     Json?
  providerResponse    Json?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  recipients          BulkBrandMessageRecipient[]

  @@index([ownerUserId, createdAt(sort: Desc)])
}

model BulkBrandMessageRecipient {
  id                   String                   @id @default(cuid())
  campaignId           String
  campaign             BulkBrandMessageCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  managedUserId        String?
  managedUser          ManagedUser?             @relation(fields: [managedUserId], references: [id], onDelete: SetNull)
  recipientPhone       String
  recipientName        String?
  recipientSeq         String?
  recipientGroupingKey String?
  templateParameters   Json?
  status               BulkSmsRecipientStatus   @default(REQUESTED)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  @@index([campaignId, createdAt(sort: Asc)])
  @@index([managedUserId])
}

model MessageAttempt {
  id               String         @id @default(cuid())
  messageRequestId String
  messageRequest   MessageRequest @relation(fields: [messageRequestId], references: [id], onDelete: Cascade)
  attemptNumber    Int
  providerRequest  Json?
  providerResponse Json?
  errorCode        String?
  errorMessage     String?
  createdAt        DateTime       @default(now())

  @@unique([messageRequestId, attemptNumber])
}

model WebhookEvent {
  id           String    @id @default(cuid())
  receivedAt   DateTime  @default(now())
  headersJson  Json
  bodyJson     Json
  verified     Boolean   @default(false)
  eventType    String
  processedAt  DateTime?
  processError String?
}

model DeadLetter {
  id               String         @id @default(cuid())
  messageRequestId String
  messageRequest   MessageRequest @relation(fields: [messageRequestId], references: [id], onDelete: Cascade)
  queueName        String
  payload          Json
  errorMessage     String
  failedAt         DateTime       @default(now())
}
